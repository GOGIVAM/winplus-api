PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# PostgreSQL — identifiants de connexion à la base de données
DB_HOST=votre_hote_postgresql
DB_PORT=5432
DB_NAME=winplus_db
DB_USER=votre_utilisateur_db
DB_PASSWORD=votre_mot_de_passe_db

# JWT — clé secrète pour signer les tokens (doit correspondre au backend .NET)
JWT_SECRET_KEY=votre_cle_secrete_jwt
JWT_ALGORITHM=HS256

# DeepSeek — API LLM pour la génération IA (quiz, analyse de progression)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=votre_cle_api_deepseek
DEEPSEEK_MODEL=deepseek-chat

# NLP — modèle de traitement du langage naturel
NLP_MODEL=camembert-base
MODEL_CACHE_DIR=./models_cache

# Feature flags — activer/désactiver les modules IA
ENABLE_RECOMMENDATIONS=true
ENABLE_QUIZ_GENERATION=true
ENABLE_PROGRESS_ANALYSIS=true

# AWS S3 — stockage des fichiers PDF (épreuves, corrigés)
# Injecter via variables d'environnement systemd ou AWS Secrets Manager en production
AWS_ACCESS_KEY_ID=votre_aws_access_key_id
AWS_SECRET_ACCESS_KEY=votre_aws_secret_access_key
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=votre_bucket_s3
