# FastAPI Configuration (Updated from FastApi)
LOG_LEVEL=info
PORT=8000
ENVIRONMENT=development

# Database Configuration (PostgreSQL - Shared with ASP.NET)
DB_USER=miguel
DB_PASSWORD=Mkomegmbdysdia4
DB_HOST=localhost
DB_PORT=5432
DB_NAME=winplus_db
DATABASE_URL=postgresql://miguel:Mkomegmbdysdia4@localhost:5432/winplus_db

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# DeepSeek Configuration
DEEPSEEK_BASE_URL=http://localhost:8000
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TEMPERATURE=0.7

# NLP Models
NLP_MODEL=camembert-base
MODEL_CACHE_DIR=./models_cache

# Rate Limiting (slowapi)
RATELIMIT_STORAGE_URL=memory://

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=detailed

# AI/ML Features
ENABLE_RECOMMENDATIONS=true
ENABLE_QUIZ_GENERATION=true
ENABLE_PROGRESS_ANALYSIS=true
ENABLE_LEARNING_PATHS=true
