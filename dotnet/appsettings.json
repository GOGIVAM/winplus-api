{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=5432;Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};Include Error Detail=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "Auth": {
    "UseCustomAuth": true,
    "EmailVerificationExpirationHours": 24,
    "PasswordResetExpirationHours": 1,
    "RememberMeDays": 30
  },
  
  "JWT": {
    "SecretKey": "dev-secret-key-min-32-chars-for-HS256-local-only",
    "Issuer": "WinPlusApp",
    "Audience": "WinPlusUsers",
    "AccessTokenExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 30,
    "ValidateLifetime": true,
    "ClockSkew": "00:05:00"
  },
  
  "SendGrid": {
    "ApiKey": "${SENDGRID_API_KEY}",
    "FromEmail": "support@gogivam.com",
    "FromName": "WinPlus Support"
  },
  
  "Payment": {
    "MtnMomo": {
      "SubscriptionKey": "${MTN_SUBSCRIPTION_KEY}",
      "ApiUser": "${MTN_API_USER}",
      "ApiKey": "${MTN_API_KEY}",
      "Environment": "production",
      "CallbackUrl": "https://api.reussir.app/api/payments/mtn/callback"
    },
    "OrangeMoney": {
      "ClientId": "${ORANGE_CLIENT_ID}",
      "ClientSecret": "${ORANGE_CLIENT_SECRET}",
      "MerchantKey": "${ORANGE_MERCHANT_KEY}",
      "NotifUrl": "https://api.reussir.app/api/payments/orange/notify"
    },
    "Wave": {
      "ApiKey": "${WAVE_API_KEY}",
      "Currency": "XOF"
    },
    "Stripe": {
      "SecretKey": "${STRIPE_SECRET_KEY}",
      "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
      "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
      "Currency": "eur"
    },
    "PayPal": {
      "ClientId": "${PAYPAL_CLIENT_ID}",
      "ClientSecret": "${PAYPAL_CLIENT_SECRET}",
      "IsSandbox": "false",
      "WebhookId": "${PAYPAL_WEBHOOK_ID}"
    }
  },
  
  "OAuth": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
      "RedirectUri": "http://localhost:5001/api/auth/callback/google"
    },
    "Facebook": {
      "AppId": "YOUR_FACEBOOK_APP_ID",
      "AppSecret": "YOUR_FACEBOOK_APP_SECRET",
      "RedirectUri": "http://localhost:5001/api/auth/callback/facebook"
    }
  },
  
  "TwoFactor": {
    "Enabled": true,
    "TotpWindowSize": 1,
    "BackupCodesCount": 10
  },
  
  "Flask": {
    "BaseUrl": "http://localhost:8000"
  },
  
  "Chatbot": {
    "MaxTokens": 2000,
    "Temperature": 0.7
  },
  
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 60,
    "RetryAttempts": 3,
    "EnableCircuitBreaker": true,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerBreakDuration": "00:00:30"
  },
  
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5001"
      },
      "Https": {
        "Url": "https://localhost:7023"
      }
    }
  },
  
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://winplus.cm",
      "https://www.winplus.cm",
      "https://winplus.com",
      "https://gogivamback.com"
    ]
  },
  
  "Swagger": {
    "Enabled": true,
    "Title": "WinPlus Educational API",
    "Version": "v4.0",
    "Description": "API avec authentification custom (migration depuis Cognito)",
    "ContactName": "Support Technique",
    "ContactEmail": "support@winplus.com"
  }
}
